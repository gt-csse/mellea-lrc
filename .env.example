# Label Studio credentials
LS_URL=https://your-label-studio-instance.com
LS_EMAIL=your@email.com
LS_PASSWORD=your_password_here
LS_PROJECT_ID=123

# CourtListener API
COURTLISTENER_API_TOKEN=your_courtlistener_api_token

LS_ACCOUNT_AUTH=<label-studio-refresh-token-for-modal>
LS_PROJECT_ID=<project_id>

# Shared CourtListener access service used by validation
CL_ACCESS_MODAL_URL=<cl-access-service-url>

# Deployed Modal app used by local smoke tests
MELLEA_LRC_MODAL_URL=<mellea-lrc-modal-app-url>

# LLM used by Mellea-assisted assessment
# DigitalOcean/Gradient serverless inference is OpenAI-compatible.
MELLEA_LRC_ASSESSMENT_BACKEND=openai
MELLEA_LRC_ASSESSMENT_API_BASE=https://inference.do-ai.run/v1
MELLEA_LRC_ASSESSMENT_API_KEY=<digitalocean-model-access-key>
MELLEA_LRC_ASSESSMENT_MODEL=<digitalocean-gemma-32b-model-id>
MELLEA_LRC_ASSESSMENT_TEMPERATURE=0
