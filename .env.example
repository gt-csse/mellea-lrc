# Label Studio credentials
LS_URL=https://your-label-studio-instance.com
LS_EMAIL=your@email.com
LS_PASSWORD=your_password_here
LS_PROJECT_ID=123

# CourtListener API
COURTLISTENER_API_TOKEN=your_courtlistener_api_token

# Mellea LLM (OpenAI-compatible API)
MELLEA_LRC_LLM_MODEL=your_model_name
MELLEA_LRC_LLM_API_BASE=https://your-llm-api.example/v1
MELLEA_LRC_LLM_API_KEY=your_llm_api_key

# Optional Mellea LLM controls
MELLEA_LRC_LLM_TEMPERATURE=0.0
