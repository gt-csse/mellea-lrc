# Label Studio credentials (upload-only: pre-annotate extracted tasks and push to LS)
LS_URL=https://your-label-studio-instance.com
LS_EMAIL=your@email.com
LS_PASSWORD=your_password_here
LS_PROJECT_ID=<project_id>

# Shared CourtListener access service used by validation
CL_ACCESS_MODAL_URL=<cl-access-service-url>

# Deployed Modal app used by local smoke tests
MELLEA_LRC_MODAL_URL=<mellea-lrc-modal-app-url>

# OpenAI-compatible API used by Mellea-backed pipeline stages.
MELLEA_LRC_LLM_TEMPERATURE=0
MELLEA_LRC_LLM_MODEL=<model-id>
MELLEA_LRC_LLM_API_BASE=<openai-compatible-api-base>
MELLEA_LRC_LLM_API_KEY=<api-key>
MELLEA_LRC_LLM_RESPONSE_FORMAT=json_schema # json_schema or json_object
MELLEA_LRC_LLM_CERT_REQUIRED=true

# Use json_object when the endpoint does not accept JSON Schema response formats.
# Disable certificate verification only for an endpoint that requires this workaround.
