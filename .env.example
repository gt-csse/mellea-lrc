# Label Studio credentials
LS_URL=https://your-label-studio-instance.com
LS_EMAIL=your@email.com
LS_PASSWORD=your_password_here
LS_PROJECT_ID=123

# CourtListener API
COURTLISTENER_API_TOKEN=your_courtlistener_api_token

LS_ACCOUNT_AUTH=<label-studio-refresh-token-for-modal>
LS_PROJECT_ID=<project_id>

# Shared CourtListener access service used by validation
CL_ACCESS_MODAL_URL=<cl-access-service-url>

# Deployed Modal app used by local smoke tests
MELLEA_LRC_MODAL_URL=<mellea-lrc-modal-app-url>

# LLM used by Mellea-backed pipeline stages (assessment, future extraction).
# Set MELLEA_LRC_LLM_PROVIDER to openrouter or digitalocean.
MELLEA_LRC_LLM_BACKEND=openai
MELLEA_LRC_LLM_PROVIDER=openrouter
MELLEA_LRC_LLM_TEMPERATURE=0

# OpenRouter hook
MELLEA_LRC_LLM_MODEL=openai/gpt-4.1-mini
MELLEA_LRC_LLM_API_BASE=https://openrouter.ai/api/v1
MELLEA_LRC_LLM_API_KEY=<openrouter-api-key>
# Require an OpenRouter provider that supports all requested params,
# including structured JSON schema output.
MELLEA_LRC_LLM_REQUIRE_PARAMETERS=1

# DigitalOcean Gradient Serverless Inference hook
DIGITALOCEAN_INFERENCE_MODEL=openai-gpt-oss-20b
DIGITALOCEAN_INFERENCE_API_BASE=https://inference.do-ai.run/v1
DIGITALOCEAN_INFERENCE_API_KEY=<digitalocean-inference-key>
